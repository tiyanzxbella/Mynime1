{"data":[{"id":150,"series_id":"majo-tabitabi-sub-indo","bookmark":null,"cover":"https://assets.animekita.org/cover/2026/03/10/series-150-anilist-112609-122006-b456eda3.jpg","judul":"Majo no Tabitabi","type":"TV","countdown":null,"status":"Completed","rating":"7.4","published":"Oct 2, 2020","author":"C2C","genre":["Adventure","Fantasy"],"genreurl":["Adventure","Fantasy"],"sinopsis":"Nonton Anime tanpa iklan di Aplikasi AnimeLovers V3 \nTerinspirasi dari buku favoritnya, Elaina memulai perjalanan untuk melihat langsung dunia yang selama ini hanya ia baca. Bagai daun tertiup angin, ia mengembara dari satu negeri ke negeri lain demi memuaskan rasa ingin tahunya dan mencari pengalaman baru.\n\nDi setiap tempat, Elaina berhadapan dengan beragam sisi kemanusiaan, kadang aneh dan tak terduga, kadang begitu mengusik perasaan. Dengan rasa penasaran sebagai kompasnya, perjalanan ini terus membawanya melangkah maju. Kali ini, Elaina akan singgah ke mana?","history":["1"],"historyDurasi":[1],"historyDurasiFull":[1],"chapter":[{"id":846,"ch":"12 (End)","url":"mnt-episode-12-sub-indo/","date":"4 Januari,2021","history":"","lastDurasi":null,"fullDurasi":null},{"id":843,"ch":"11","url":"mnt-episode-11-sub-indo/","date":"4 Januari,2021","history":"","lastDurasi":null,"fullDurasi":null},{"id":842,"ch":"10","url":"mnt-episode-10-sub-indo/","date":"4 Januari,2021","history":"","lastDurasi":null,"fullDurasi":null},{"id":840,"ch":"9","url":"mnt-episode-9-sub-indo/","date":"4 Januari,2021","history":"","lastDurasi":null,"fullDurasi":null},{"id":841,"ch":"8","url":"mnt-episode-8-sub-indo/","date":"4 Januari,2021","history":"","lastDurasi":null,"fullDurasi":null},{"id":2600,"ch":"7","url":"mnt-episode-7-sub-indo/","date":"4 Januari,2021","history":"","lastDurasi":null,"fullDurasi":null},{"id":2385,"ch":"6","url":"mnt-episode-6-sub-indo/","date":"4 Januari,2021","history":"","lastDurasi":null,"fullDurasi":null},{"id":2318,"ch":"5","url":"mnt-episode-5-sub-indo/","date":"4 Januari,2021","hist